pipeline {
    agent any 

    environment {
        REGISTRY = "docker.io/karisuta7" 
        IMAGE_NAME = "taskflow-api"
        DOCKER_CREDS = 'docker-hub-credentials'
        SUB_DIR = 'pertemuan-09-cicd/pbl-taskflow-go'
    }

    stages {
        stage('Skenario 6: Security Scan') {
            agent {
                docker { 
                    // Kita pakai Go terbaru khusus untuk SCAN agar tool gosec bisa jalan
                    image 'golang:latest' 
                    args "-u root"
                } 
            }
            steps {
                dir("${SUB_DIR}") {
                    sh '''
                        export GOPATH=/tmp/go
                        export GOCACHE=/tmp/.cache
                        export PATH=$PATH:/tmp/go/bin
                        go mod download
                        
                        echo "Running SAST & SCA..."
                        /tmp/go/bin/gosec -fmt json -out gosec-report.json ./... || true
                        /tmp/go/bin/govulncheck ./... > vuln-report.txt || true
                    '''
                    // PERBAIKAN: Path artifact harus langsung ke nama filenya karena kita sudah di dalam 'dir'
                    archiveArtifacts artifacts: "gosec-report.json, vuln-report.txt", allowEmptyArchive: true
                }
            }

        stage('Build & Push (Skenario 3)') {
            steps {
                script {
                    dir("${SUB_DIR}") {
                        docker.withRegistry('', DOCKER_CREDS) {
                            // Makefile akan mem-build image menggunakan Dockerfile (Go 1.22)
                            sh "make docker-build REGISTRY=${REGISTRY}"
                            sh "make docker-push REGISTRY=${REGISTRY}"
                        }
                    }
                }
            }
        }

        stage('Smoke Test (Skenario 4)') {
            steps {
                dir("${SUB_DIR}") {
                    sh '''
                        docker stop taskflow-api || true
                        docker rm taskflow-api || true
                        docker run -d --name taskflow-api -p 8080:8080 ${REGISTRY}/${IMAGE_NAME}:latest
                        sleep 5
                        curl -sf http://localhost:8080/health || exit 1
                        echo "✅ Smoke test berhasil"
                    '''
                }
            }
        }

        stage('Skenario 5: Update Stable Tag') {
            steps {
                script {
                    dir("${SUB_DIR}") {
                        docker.withRegistry('', DOCKER_CREDS) {
                            sh "make docker-stable REGISTRY=${REGISTRY}"
                        }
                    }
                }
            }
        }
    }
}
